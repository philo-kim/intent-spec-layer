{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Intent Specification Layer frontmatter",
  "type": "object",
  "required": ["id", "title", "status", "owners", "updated", "layers"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^SPEC-[A-Z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "adopted", "active", "stable", "deprecated", "archived"]
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "layers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["L0", "L1", "L2", "L3"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "target_release": {
      "type": "string",
      "enum": ["current", "next", "later", "unscheduled"]
    }
  },
  "additionalProperties": true
}
